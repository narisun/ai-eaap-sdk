[build-system]
requires = ["hatchling>=1.21"]
build-backend = "hatchling.build"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "Generated EAAP application."
requires-python = ">=3.11"

# IMPORTANT: ai-eaap-sdk is intentionally NOT listed here.
#
# The SDK is not yet published to PyPI. Install it from source separately:
#
#     pip install -e /path/to/ai-eaap-sdk
#
# (Context: the PyPI name `ai-core-sdk` is SAP's unrelated AI Core client
# — do not install that one.)
#
# When the SDK is published, uncomment the line below with the matching
# version pin.
#
# dependencies = [
#     "ai-eaap-sdk>=0.1.0",
#     "uvicorn[standard]>=0.29.0",
# ]
dependencies = [
    "uvicorn[standard]>=0.29.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.1",
    "pytest-asyncio>=0.23",
    "ruff>=0.4",
    "mypy>=1.10",
]

[project.scripts]
{{ project_package }} = "{{ project_package }}.main:main"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_package }}"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
