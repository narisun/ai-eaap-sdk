# Copy to `.env` and fill in real values.

EAAP_ENVIRONMENT=local
EAAP_SERVICE_NAME={{ service_name }}

# Database
EAAP_DATABASE__DSN=postgresql+asyncpg://eaap:eaap@localhost:5432/eaap

# LLM (LiteLLM)
EAAP_LLM__DEFAULT_MODEL=bedrock/anthropic.claude-sonnet-4-6
# EAAP_LLM__PROXY_BASE_URL=http://localhost:4000
# EAAP_LLM__PROXY_API_KEY=sk-...

# Observability
EAAP_OBSERVABILITY__OTEL_ENDPOINT=http://localhost:4317
# EAAP_OBSERVABILITY__LANGFUSE_HOST=https://cloud.langfuse.com
# EAAP_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
# EAAP_OBSERVABILITY__LANGFUSE_SECRET_KEY=

# Security (OPA)
EAAP_SECURITY__OPA_URL=http://localhost:8181
EAAP_SECURITY__OPA_DECISION_PATH=eaap/api/allow
EAAP_SECURITY__FAIL_CLOSED=true
# EAAP_SECURITY__JWT_AUDIENCE=
# EAAP_SECURITY__JWT_ISSUER=

# --- Phase 4 settings (uncomment and customize per-deployment) ---

# Anthropic prompt caching (LLMSettings)
# EAAP_LLM__PROMPT_CACHE_ENABLED=true
# EAAP_LLM__PROMPT_CACHE_MIN_MESSAGES=6
# EAAP_LLM__PROMPT_CACHE_MIN_TOKENS=1024

# MCP connection pooling (MCPSettings)
# EAAP_MCP__POOL_ENABLED=true
# EAAP_MCP__POOL_IDLE_SECONDS=300.0

# OPA health probe path (SecuritySettings)
# EAAP_SECURITY__OPA_HEALTH_PATH=/health

# Optional: explicit YAML config path (auto-discovers ./eaap.yaml otherwise)
# EAAP_CONFIG_PATH=/etc/eaap/config.yaml
